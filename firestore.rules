rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Jobs Collection
    match /jobs/{jobId} {
      // Users can read and list their own jobs
      allow get, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      // Temporary allow for debugging
      allow create, update: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
      allow delete: if false; 
    }
  }
}
